---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const projects = [
  { src: `${base}images/p-gougeres.jpg`,        alt: 'Gougeres cheese puffs overhead',             width: 1200, height: 1799 },
  { src: `${base}images/p-salmon.jpg`,          alt: 'Baked salmon with vegetables',               width: 1200, height: 1799 },
  { src: `${base}images/p-doner.jpg`,           alt: 'Doner kebab on orange background',           width: 1200, height: 1799 },
  { src: `${base}images/p-madeleines.jpg`,      alt: 'Honey madeleines flat lay',                  width: 1200, height: 1800 },
  { src: `${base}images/p-arrosticini-2.jpg`,   alt: 'Arrosticini skewers with red wine',          width: 1200, height: 1799 },
  { src: `${base}images/p-french-toast.jpg`,    alt: 'French toast with berries and honey',        width: 1200, height: 1799 },
  { src: `${base}images/p-pide.jpg`,            alt: 'Peynirli pide Turkish flatbread overhead',   width: 1200, height: 1799 },
  { src: `${base}images/p-chouquettes-box.jpg`, alt: 'Chouquettes in a wooden gift box',           width: 1200, height: 1799 },
  { src: `${base}images/p-gnocchi-soup.jpg`,    alt: 'Gnocchi chicken soup in enamel pot',         width: 1200, height: 1799 },
  { src: `${base}images/p-garden-table.jpg`,    alt: 'Garden dining table at golden hour',         width: 1200, height: 1799 },
  { src: `${base}images/p-flatbread.jpg`,       alt: 'Turkish flatbread with cheese and olives',   width: 1200, height: 900  },
  { src: `${base}images/p-candlelit-cake.jpg`,  alt: 'Walnut cake with candle and champagne',      width: 1200, height: 799  },
  { src: `${base}images/p-bundt-cake.jpg`,      alt: 'Bundt cake with flour and cranberries',      width: 1200, height: 1799 },
  { src: `${base}images/p-ingredients.jpg`,     alt: 'Fresh salad ingredients editorial overhead', width: 1200, height: 1798 },
  { src: `${base}images/p-pizzicotti.jpg`,      alt: 'Pizzicotti almond cookies overhead',         width: 1200, height: 1799 },
  { src: `${base}images/p-doner-wrap.jpg`,      alt: 'Doner kebab wrap on red background',         width: 1200, height: 1799 },
];
---

<Layout title="Portfolio" description="Food photography work by Studio Roux.">

  <section class="bg-[#d70046]">
    <div class="max-w-7xl mx-auto px-6 py-6 md:py-12 flex items-end justify-between">
      <div>
        <p class="font-body text-xs font-semibold tracking-[0.3em] uppercase text-[#ffc928] mb-1">Portfolio</p>
        <h1 class="font-display font-bold text-[clamp(2rem,5vw,5rem)] text-white leading-none tracking-tight">OUR WORK</h1>
      </div>
    </div>
  </section>

  <section class="bg-[#faf8f3]">
    <div class="max-w-7xl mx-auto px-6 py-10">
      <div class="columns-1 md:columns-2 lg:columns-3 gap-4 space-y-4">
        {projects.map((project) => (
          <div class="group relative overflow-hidden break-inside-avoid cursor-pointer">
            <img
              src={project.src}
              alt={project.alt}
              width={project.width}
              height={project.height}
              loading="lazy"
              class="w-full object-cover block transition-transform duration-500 group-hover:scale-105"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
