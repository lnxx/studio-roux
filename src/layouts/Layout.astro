---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Studio Roux',
  description = 'Food photography studio. We make food irresistible.',
} = Astro.props;

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}favicon.png`} />
    <title>{title === 'Studio Roux' ? title : `${title} | Studio Roux`}</title>
  </head>
  <body>

    <header class="sticky top-0 z-50 bg-white border-b border-[#e8e8e8]">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href={`${base}/`} aria-label="Studio Roux home" class="flex-shrink-0">
          <img
            src={`${import.meta.env.BASE_URL}images/logo-1x.png`}
            srcset={`${import.meta.env.BASE_URL}images/logo-1x.png 1x, ${import.meta.env.BASE_URL}images/logo.png 2x`}
            alt="Studio Roux"
            width="72"
            height="32"
            class="h-6 md:h-8 w-auto block"
            style="aspect-ratio: 883/394;"
          />
        </a>
        <nav aria-label="Main navigation">
          <ul class="flex items-center gap-0 md:gap-1">
            <li>
              <a
                href={`${base}/portfolio`}
                class={`px-3 md:px-4 py-2 text-xs md:text-sm font-body font-semibold tracking-widest uppercase transition-colors duration-150 ${currentPath.includes('/portfolio') ? 'text-[#d70046]' : 'text-[#111111] hover:text-[#d70046]'}`}
              >Work</a>
            </li>
            <li>
              <a
                href={`${base}/about`}
                class={`px-3 md:px-4 py-2 text-xs md:text-sm font-body font-semibold tracking-widest uppercase transition-colors duration-150 ${currentPath.includes('/about') ? 'text-[#d70046]' : 'text-[#111111] hover:text-[#d70046]'}`}
              >About</a>
            </li>
            <li>
              <a
                href={`${base}/contact`}
                class="ml-1 md:ml-2 px-4 md:px-5 py-2 bg-[#d70046] text-white text-xs md:text-sm font-semibold tracking-widest uppercase border-2 border-[#d70046] shadow-none md:shadow-[3px_3px_0_#111111] hover:translate-x-[3px] hover:translate-y-[3px] md:hover:shadow-none transition-all duration-150 cursor-pointer"
              >Contact</a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-[#111111] text-white">
      <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row items-start justify-between gap-8">
        <div>
          <img
            src={`${import.meta.env.BASE_URL}images/logo-1x.png`}
            alt="Studio Roux"
            width="100"
            height="44"
            class="h-7 w-auto brightness-0 invert mb-4"
          />
          <p class="text-sm text-[#888888] max-w-xs font-body">
            Food photography studio. We make every dish look as good as it tastes.
          </p>
        </div>
        <nav aria-label="Footer navigation">
          <ul class="flex flex-col gap-2 text-sm font-body font-medium tracking-widest uppercase">
            <li><a href={`${base}/portfolio`} class="text-[#888888] hover:text-[#ffc928] transition-colors duration-150">Work</a></li>
            <li><a href={`${base}/about`} class="text-[#888888] hover:text-[#ffc928] transition-colors duration-150">About</a></li>
            <li><a href={`${base}/contact`} class="text-[#888888] hover:text-[#ffc928] transition-colors duration-150">Contact</a></li>
          </ul>
        </nav>
      </div>
      <div class="border-t border-[#222222]">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between text-xs text-[#555555] tracking-widest uppercase font-body">
          <span>© {new Date().getFullYear()} Studio Roux</span>
          <span>Food Photography</span>
        </div>
      </div>
    </footer>

  </body>
</html>
