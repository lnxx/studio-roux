---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Studio Roux" description="Food photography studio. We craft images that make people hungry.">

  <!-- Hero -->
  <section class="relative min-h-dvh flex flex-col justify-end px-6 pb-16 md:pb-24 overflow-hidden">
    <div class="absolute inset-0 bg-zinc-900">
      <img
        src="/images/hero.jpg"
        alt=""
        class="w-full h-full object-cover opacity-70"
        width="1920"
        height="1080"
      />
    </div>
    <div class="relative z-10 max-w-4xl">
      <p class="text-xs tracking-[0.3em] uppercase text-zinc-400 mb-6">Food Photography Studio</p>
      <h1 class="font-heading text-5xl md:text-7xl lg:text-8xl font-black leading-none mb-8">
        We make food<br /><em>irresistible.</em>
      </h1>
      <a
        href="/portfolio"
        class="inline-block border border-white px-8 py-3 text-sm tracking-widest uppercase hover:bg-white hover:text-black transition-colors duration-300"
      >
        View Work
      </a>
    </div>
  </section>

  <!-- Selected Work Preview -->
  <section class="px-6 py-24 md:py-32">
    <div class="flex items-baseline justify-between mb-12">
      <h2 class="font-heading text-3xl md:text-4xl font-bold">Selected Work</h2>
      <a href="/portfolio" class="text-xs tracking-widest uppercase text-zinc-400 hover:text-white transition-colors duration-200">
        All Projects →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="group relative overflow-hidden bg-zinc-900 aspect-[4/3]">
        <img src="/images/work-1.jpg" alt="Editorial shoot — seasonal produce" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" width="800" height="600" loading="lazy" />
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-300"></div>
        <div class="absolute bottom-0 left-0 p-6 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
          <p class="font-heading text-lg font-bold">Editorial</p>
          <p class="text-xs tracking-widest uppercase text-zinc-300">Seasonal Produce</p>
        </div>
      </div>

      <div class="group relative overflow-hidden bg-zinc-900 aspect-[4/3]">
        <img src="/images/work-2.jpg" alt="Commercial shoot — restaurant campaign" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" width="800" height="600" loading="lazy" />
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-300"></div>
        <div class="absolute bottom-0 left-0 p-6 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
          <p class="font-heading text-lg font-bold">Commercial</p>
          <p class="text-xs tracking-widest uppercase text-zinc-300">Restaurant Campaign</p>
        </div>
      </div>

      <div class="group relative overflow-hidden bg-zinc-900 aspect-[4/3] md:col-span-2 md:aspect-[16/7]">
        <img src="/images/work-3.jpg" alt="Packaging shoot — artisan brand" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" width="1600" height="700" loading="lazy" />
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-300"></div>
        <div class="absolute bottom-0 left-0 p-6 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
          <p class="font-heading text-lg font-bold">Packaging</p>
          <p class="text-xs tracking-widest uppercase text-zinc-300">Artisan Brand</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote break -->
  <section class="border-t border-zinc-800 px-6 py-24 md:py-32 text-center">
    <p class="font-heading text-3xl md:text-5xl lg:text-6xl font-black max-w-4xl mx-auto leading-tight">
      "Every dish has a story.<br /><em>We tell it with light."</em>
    </p>
  </section>

  <!-- CTA -->
  <section class="px-6 pb-24 md:pb-32 text-center">
    <p class="text-sm tracking-widest uppercase text-zinc-400 mb-6">Let's work together</p>
    <a
      href="/contact"
      class="inline-block border border-white px-12 py-4 font-heading text-xl font-bold hover:bg-white hover:text-black transition-colors duration-300"
    >
      Get in Touch
    </a>
  </section>

</Layout>
