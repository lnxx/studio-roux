---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="About" description="Studio Roux is an Antalya-based creative studio dedicated to the intersection of gastronomy and design.">

  <section class="bg-[#d70046]">
    <div class="max-w-7xl mx-auto px-6 py-4 md:py-10">
      <p class="font-body text-xs font-semibold tracking-[0.3em] uppercase text-[#ffc928] mb-1">About</p>
      <h1 class="font-display font-bold text-[clamp(1.5rem,3.5vw,3rem)] text-white leading-none tracking-tight">
        STUDIO ROUX
      </h1>
    </div>
  </section>

  <section class="bg-[#faf8f3]">
    <div class="max-w-7xl mx-auto px-6 pt-6 pb-6 md:pt-16 md:pb-12">

      <h2 class="font-display font-bold text-[clamp(1.9rem,6vw,5.8rem)] text-[#111111] leading-[0.95] tracking-tight mb-3">
        WE VIEW FOOD<br />THROUGH A<br /><span class="text-[#d70046]">DESIGNER'S</span><br />LENS.
      </h2>

      <div class="mb-4">
        <span class="inline-block bg-[#ffc928] text-[#111111] font-body text-xs font-semibold tracking-[0.25em] uppercase px-3 py-1">
          Antalya, Turkey
        </span>
      </div>

      <div class="border-t border-[#111111]/15 pt-5 grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-16">
        <p class="font-body text-sm md:text-lg text-[#111111] leading-normal">
          Studio Roux is a creative studio dedicated to the intersection of gastronomy and design, blending aesthetic precision with strategic commercial growth.
        </p>
        <p class="font-body text-sm md:text-base text-[#555555] leading-normal">
          From cinematic food photography and menu engineering to brand consultancy and digital management, we deliver interdisciplinary solutions for restaurants, hotels, and agricultural brands, collaborating with local and global partners from concept to execution.
        </p>
      </div>

    </div>
  </section>

  <section class="bg-[#faf8f3] border-t border-[#111111]/10">
    <div class="max-w-7xl mx-auto px-6 py-6 md:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-20 items-center">

        <div>
          <span class="inline-block bg-[#ffc928] text-[#111111] font-body text-xs font-semibold tracking-[0.25em] uppercase px-3 py-1 mb-4">
            Approach
          </span>
          <h2 class="font-display font-bold text-[clamp(1.6rem,3.5vw,3.5rem)] text-[#111111] leading-[0.97] tracking-tight mb-3">
            INTERDISCIPLINARY<br />BY DESIGN.
          </h2>
          <p class="font-body text-sm md:text-base text-[#555555] leading-normal mb-0 max-w-md">
            We collaborate with a curated network of chefs, architects, dietitians, editors, and industry experts, ensuring every project is shaped by the right expertise, creative and commercially effective in equal measure.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-[3px]">
          {[
            ['Chefs',         'bg-[#d70046] text-white'],
            ['Architects',    'bg-[#ffc928] text-[#111111]'],
            ['Dietitians',    'bg-[#ffc928] text-[#111111]'],
            ['Writers',       'bg-[#d70046] text-white'],
            ['Editors',       'bg-[#d70046] text-white'],
            ['Stylists',      'bg-[#ffc928] text-[#111111]'],
            ['Strategists',   'bg-[#ffc928] text-[#111111]'],
            ['Photographers', 'bg-[#d70046] text-white'],
          ].map(([label, classes]) => (
            <div class={`px-4 py-3 md:px-5 md:py-5 ${classes} font-body font-semibold text-xs md:text-sm tracking-widest uppercase`}>
              {label}
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

</Layout>
