---
import Layout from '../layouts/Layout.astro';

const projects = [
  { src: '/images/work-1.jpg', alt: 'Editorial — seasonal produce', category: 'Editorial', title: 'Seasonal Produce', width: 800, height: 600 },
  { src: '/images/work-2.jpg', alt: 'Commercial — restaurant campaign', category: 'Commercial', title: 'Restaurant Campaign', width: 800, height: 1000 },
  { src: '/images/work-3.jpg', alt: 'Packaging — artisan brand', category: 'Packaging', title: 'Artisan Brand', width: 800, height: 600 },
  { src: '/images/work-4.jpg', alt: 'Editorial — fine dining', category: 'Editorial', title: 'Fine Dining', width: 800, height: 1000 },
  { src: '/images/work-5.jpg', alt: 'Commercial — recipe book', category: 'Commercial', title: 'Recipe Book', width: 800, height: 600 },
  { src: '/images/work-6.jpg', alt: 'Packaging — beverage line', category: 'Packaging', title: 'Beverage Line', width: 800, height: 600 },
];
---

<Layout title="Portfolio" description="Selected food photography work by Studio Roux.">

  <section class="pt-32 px-6 pb-24">
    <div class="mb-16">
      <p class="text-xs tracking-[0.3em] uppercase text-zinc-500 mb-4">Portfolio</p>
      <h1 class="font-heading text-5xl md:text-6xl font-black">Selected Work</h1>
    </div>

    <!-- Masonry grid -->
    <div class="columns-1 md:columns-2 lg:columns-3 gap-4 space-y-4">
      {projects.map((project) => (
        <div class="group relative overflow-hidden bg-zinc-900 break-inside-avoid">
          <img
            src={project.src}
            alt={project.alt}
            width={project.width}
            height={project.height}
            loading="lazy"
            class="w-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-colors duration-300"></div>
          <div class="absolute bottom-0 left-0 p-5 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
            <p class="text-xs tracking-widest uppercase text-zinc-300 mb-1">{project.category}</p>
            <p class="font-heading text-lg font-bold">{project.title}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

</Layout>
