---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="Studio Roux — a food photography studio built on craft, light, and obsession with the plate.">

  <section class="pt-32 px-6 pb-24 max-w-5xl mx-auto">

    <div class="mb-20">
      <p class="text-xs tracking-[0.3em] uppercase text-zinc-500 mb-4">About</p>
      <h1 class="font-heading text-5xl md:text-6xl font-black leading-tight">
        We photograph food<br /><em>as it deserves to be seen.</em>
      </h1>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
      <div>
        <!-- Replace with studio/portrait image -->
        <div class="aspect-[3/4] bg-zinc-900 overflow-hidden">
          <img
            src="/images/studio.jpg"
            alt="Studio Roux workspace"
            width="600"
            height="800"
            loading="lazy"
            class="w-full h-full object-cover"
          />
        </div>
      </div>

      <div class="space-y-8 pt-2">
        <p class="text-lg leading-relaxed text-zinc-300">
          Studio Roux is a food photography studio specialising in editorial, commercial, and packaging work. We collaborate with restaurants, food brands, and publishers to create imagery that communicates flavour, texture, and craft.
        </p>
        <p class="leading-relaxed text-zinc-400">
          Every project begins with understanding the story behind the food — the ingredients, the process, the people. That story shapes every frame.
        </p>

        <div class="border-t border-zinc-800 pt-8 space-y-4">
          <h2 class="font-heading text-xl font-bold">Services</h2>
          <ul class="space-y-2 text-zinc-400 text-sm tracking-wide">
            <li class="flex items-center gap-3">
              <span class="w-1 h-1 rounded-full bg-zinc-500 shrink-0"></span>
              Editorial & Magazine
            </li>
            <li class="flex items-center gap-3">
              <span class="w-1 h-1 rounded-full bg-zinc-500 shrink-0"></span>
              Restaurant & Hospitality
            </li>
            <li class="flex items-center gap-3">
              <span class="w-1 h-1 rounded-full bg-zinc-500 shrink-0"></span>
              Product & Packaging
            </li>
            <li class="flex items-center gap-3">
              <span class="w-1 h-1 rounded-full bg-zinc-500 shrink-0"></span>
              Recipe Books & Publishing
            </li>
            <li class="flex items-center gap-3">
              <span class="w-1 h-1 rounded-full bg-zinc-500 shrink-0"></span>
              Social Media Content
            </li>
          </ul>
        </div>

        <div class="border-t border-zinc-800 pt-8">
          <a
            href="/contact"
            class="inline-block border border-white px-8 py-3 text-sm tracking-widest uppercase hover:bg-white hover:text-black transition-colors duration-300"
          >
            Work With Us
          </a>
        </div>
      </div>
    </div>

  </section>

</Layout>
