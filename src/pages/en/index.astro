---
import Layout from '../../layouts/Layout.astro';
import { en as t } from '../../i18n/en';
const base = import.meta.env.BASE_URL;
const linkBase = '/en';

const heroImages = [
  { src: `${base}images/hero-b.jpg`, alt: 'Baked salmon with vegetables' },
  { src: `${base}images/hero-c.jpg`, alt: 'Doner kebab wrap on red background' },
  { src: `${base}images/hero-a.jpg`, alt: 'Layered sandwich on blue background' },
];
---

<Layout title={t.home.metaTitle} description={t.home.metaDescription} lang="en">

  <section class="flex flex-col lg:grid lg:grid-cols-[55%_45%] h-[100svh] lg:h-auto lg:min-h-[100svh]">

    <div class="bg-[#faf8f3] flex-shrink-0 flex flex-col justify-between px-6 py-6 lg:px-14 lg:py-14 lg:min-h-[100svh]">
      <div>
        <p class="font-body text-xs font-semibold tracking-[0.3em] uppercase text-[#d70046]">
          {t.home.heroLabel}
        </p>
      </div>

      <div>
        <h1 class="font-display font-bold text-[clamp(2.2rem,4vw,5.5rem)] leading-[0.9] tracking-tight text-[#111111] mb-3 md:mb-8">
          {t.home.heroLine1}<br />
          <span class="text-[#d70046]">{t.home.heroLine2}</span><br />
          {t.home.heroLine3}
        </h1>
        <p class="font-body text-xs md:text-base text-[#666666] max-w-xs mb-4 md:mb-10 leading-snug md:leading-relaxed">
          {t.home.heroBody}
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href={`${linkBase}/portfolio`}
            class="inline-block bg-white text-[#111111] px-5 py-2.5 md:px-7 md:py-3.5 font-body font-bold text-xs md:text-sm tracking-widest uppercase border-2 border-[#111111] shadow-[4px_4px_0_#d70046] hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none transition-all duration-150 cursor-pointer"
          >
            {t.home.heroCTAWork}
          </a>
          <a
            href={`${linkBase}/contact`}
            class="inline-block bg-[#d70046] text-white px-5 py-2.5 md:px-7 md:py-3.5 font-body font-bold text-xs md:text-sm tracking-widest uppercase border-2 border-[#d70046] shadow-[4px_4px_0_#111111] hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none transition-all duration-150 cursor-pointer"
          >
            {t.home.heroCTAContact}
          </a>
        </div>
      </div>

      <div class="hidden lg:block border-t border-[#111111]/10 pt-5">
        <p class="font-body text-xs text-[#aaaaaa] tracking-widest uppercase">{t.home.heroEst}</p>
      </div>
    </div>

    <div class="relative flex-1 lg:flex-none overflow-hidden bg-[#1a1a1a] lg:h-auto lg:min-h-[100svh]">
      {heroImages.map((img, i) => (
        <img
          src={img.src}
          alt={img.alt}
          width="800"
          height="1000"
          loading={i === 0 ? 'eager' : 'lazy'}
          class={`hero-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
        />
      ))}
    </div>
  </section>

  <section class="bg-[#d70046]">
    <div class="max-w-7xl mx-auto px-6 py-10 md:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-end">

        <div>
          <span class="inline-block bg-[#ffc928] text-[#111111] font-body text-xs font-semibold tracking-[0.25em] uppercase px-3 py-1 mb-5">{t.home.aboutLabel}</span>
          <h2 class="font-display font-bold text-[clamp(2rem,4vw,4.5rem)] text-white leading-[0.95] tracking-tight">
            {t.home.aboutHeadline.lines.map((line, i) => (
              <>
                {i > 0 && <br />}
                {i === t.home.aboutHeadline.hi
                  ? <>{t.home.aboutHeadline.hiPre}<span class="text-[#ffc928]">{line}</span></>
                  : line}
              </>
            ))}
          </h2>
        </div>

        <div class="flex flex-col gap-5">
          <p class="font-body text-sm md:text-base text-white/80 leading-relaxed">
            {t.home.aboutBody1}
          </p>
          <p class="font-body text-sm md:text-base text-white/80 leading-relaxed">
            {t.home.aboutBody2}
          </p>
          <div class="pt-2">
            <a
              href={`${linkBase}/about`}
              class="inline-block bg-white text-[#111111] px-6 py-3 font-body font-bold text-xs tracking-widest uppercase border-2 border-white shadow-[4px_4px_0_#111111] hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none transition-all duration-150 cursor-pointer"
            >
              {t.home.aboutCTA}
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 py-12 md:py-16">

      <div class="flex items-end justify-between mb-6 md:mb-10">
        <div>
          <span class="inline-block bg-[#d70046] text-white font-body text-xs font-semibold tracking-[0.25em] uppercase px-3 py-1 mb-3">{t.home.servicesLabel}</span>
          <h2 class="font-display font-bold text-[clamp(1.8rem,3.5vw,3.5rem)] text-[#111111] leading-none">{t.home.servicesHeadline}</h2>
        </div>
        <a href={`${linkBase}/contact`} class="hidden md:inline-block font-body text-sm font-semibold tracking-widest uppercase text-[#111111] border-b-2 border-[#d70046] pb-0.5 hover:text-[#d70046] transition-colors duration-150">
          {t.home.servicesCTA}
        </a>
      </div>

      <div>
        {t.home.services.map((service, i) => (
          <div class={`group grid grid-cols-1 md:grid-cols-[5fr_7fr_1.5rem] items-baseline gap-y-1 gap-x-12 py-5 md:py-6 border-l-[4px] pl-5 hover:bg-[#ffc928] transition-colors duration-150 cursor-pointer ${i % 2 === 0 ? 'border-l-[#d70046]' : 'border-l-[#ffc928]'}`}>
            <h3 class="font-display font-bold text-[1.15rem] md:text-[1.3rem] text-[#111111] uppercase leading-snug group-hover:text-[#d70046] transition-colors duration-150">
              {service.title}
            </h3>
            <p class="font-body text-sm text-[#555555] leading-relaxed group-hover:text-[#111111]/70 transition-colors duration-150">
              {service.body}
            </p>
            <span class="hidden md:block font-body text-base text-[#d70046] opacity-0 group-hover:opacity-100 transition-opacity duration-150 text-right">→</span>
          </div>
        ))}
      </div>

    </div>
  </section>

  <section class="bg-[#faf8f3]">
    <div class="max-w-7xl mx-auto px-6 py-12 md:py-16">
      <div class="flex items-end justify-between mb-6 md:mb-10">
        <div>
          <p class="font-body text-xs font-semibold tracking-[0.25em] uppercase text-[#d70046] mb-2">{t.home.portfolioLabel}</p>
          <h2 class="font-display font-bold text-[clamp(1.8rem,3.5vw,3.5rem)] text-[#111111] leading-none">{t.home.portfolioLine1}<br />{t.home.portfolioLine2}</h2>
        </div>
        <a href={`${linkBase}/portfolio`} class="font-body text-sm font-semibold tracking-widest uppercase text-[#111111] hover:text-[#d70046] transition-colors duration-150">
          {t.home.portfolioCTA}
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:[grid-template-rows:380px_280px]">
        <div class="md:col-span-8 overflow-hidden bg-[#e8e5de] aspect-[4/3] md:aspect-auto">
          <img src={`${base}images/p-gougeres.jpg`} alt="Gougeres cheese puffs overhead" class="w-full h-full object-cover" width="1200" height="1799" loading="lazy" />
        </div>
        <div class="md:col-span-4 overflow-hidden bg-[#e8e5de] aspect-[4/3] md:aspect-auto">
          <img src={`${base}images/p-arrosticini-2.jpg`} alt="Arrosticini skewers with red wine" class="w-full h-full object-cover" width="1200" height="1799" loading="lazy" />
        </div>
        <div class="md:col-span-4 overflow-hidden bg-[#e8e5de] aspect-[4/3] md:aspect-auto">
          <img src={`${base}images/p-candlelit-cake.jpg`} alt="Walnut cake with candle and champagne" class="w-full h-full object-cover" width="1200" height="799" loading="lazy" />
        </div>
        <div class="md:col-span-8 overflow-hidden bg-[#e8e5de] aspect-[4/3] md:aspect-auto">
          <img src={`${base}images/p-flatbread.jpg`} alt="Turkish flatbread with cheese and olives" class="w-full h-full object-cover" width="1200" height="900" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#d70046]">
    <div class="max-w-7xl mx-auto px-6 py-12 md:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-10 items-center">
        <div>
          <p class="font-body text-xs font-semibold tracking-[0.25em] uppercase text-white/60 mb-4">{t.home.ctaLabel}</p>
          <h2 class="font-display font-bold text-[clamp(1.8rem,3.5vw,3.8rem)] text-white leading-none mb-6">
            {t.home.ctaLine1}<br />{t.home.ctaLine2}<br />{t.home.ctaLine3}
          </h2>
          <p class="font-body text-lg text-white/70 max-w-md">
            {t.home.ctaBody}
          </p>
        </div>
        <a
          href={`${linkBase}/contact`}
          class="shrink-0 inline-block bg-[#ffc928] text-[#111111] px-6 py-3 md:px-10 md:py-5 font-display font-bold text-base md:text-2xl tracking-wider border-2 border-[#111111] shadow-[4px_4px_0_#111111] md:shadow-[6px_6px_0_#111111] hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none transition-all duration-150 cursor-pointer"
        >
          {t.home.ctaButton}
        </a>
      </div>
    </div>
  </section>

</Layout>

<script>
  localStorage.setItem('studio-roux-lang', 'en');

  const slides = document.querySelectorAll<HTMLElement>('.hero-slide');
  if (slides.length > 1) {
    let current = 0;
    setInterval(() => {
      slides[current].classList.add('opacity-0');
      slides[current].classList.remove('opacity-100');
      current = (current + 1) % slides.length;
      slides[current].classList.remove('opacity-0');
      slides[current].classList.add('opacity-100');
    }, 4000);
  }
</script>
